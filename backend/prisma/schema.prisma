generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PullRequestReview {
  id        String   @id
  owner     String
  repo      String
  number    Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Storing issues and summary as Json for flexibility with AI output
  issues    Json?
  summary   Json?
  githubReviewStatus String?
  githubReviewUrl    String?

  files PullRequestFile[]

  @@index([owner, repo, number])
}

model PullRequestFile {
  id         Int               @id @default(autoincrement())
  filename   String
  status     String
  additions  Int
  deletions  Int
  changes    Int
  patch      String?

  reviewId String
  review   PullRequestReview   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

